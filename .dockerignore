#################################################
# 🔐 Environment files
#################################################

.env
.env.*
!.env.example

#################################################
# 📦 Node dependencies (will be installed inside container)
#################################################

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

#################################################
# 🏗 Build output (Docker will build fresh)
#################################################

dist/
build/
.next/
.nuxt/
out/
coverage/

#################################################
# 🧾 Logs
#################################################

logs/
*.log

#################################################
# 🧪 Testing files
#################################################

test/
tests/
__tests__/
*.spec.ts
*.test.ts

#################################################
# 🧰 Editor / IDE files
#################################################

.vscode/
.idea/

#################################################
# 💻 OS files
#################################################

.DS_Store
Thumbs.db

#################################################
# 🌐 Git files (not needed inside container)
#################################################

.git
.gitignore
README.md
*.md

#################################################
# 🌐 Replit specific
#################################################

.replit
.replit.nix
.config/
.cache/

#################################################
# 🔑 Keys / Certificates
#################################################

*.pem
*.key
*.crt

#################################################
# 🐳 Docker local artifacts
#################################################

docker-data/
*.tar

