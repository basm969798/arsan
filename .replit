run = "bash setup.sh"
modules = ["nodejs-20"]

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 80

[nix]
packages = ["tree"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx nest start --watch"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"
